rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isUser(email) {
        return isAuth() && request.auth.token.email == email
    }

    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role == 'admin';
    }

    function isEmployee() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role == 'employee';
    }

    // Users
    match /users/{email} {
      allow read: if isUser(email) || isAdmin() || isEmployee();
      allow create: if isAdmin();
      allow update: if (isUser(email) || isAdmin()) 
                    && request.resource.data.role == resource.data.role;
    }
    
    // Orders
    match /orders/{orderId} {
      // Read access for employees and admins.
      allow read: if isEmployee() || isAdmin();

      // Delete access only for admins.
      allow delete: if isAdmin();

      // Create access for any authenticated user, with validation.
      allow create: if isAuth()
                    && request.resource.data.createdBy == request.auth.token.email
                    && request.resource.data.status == 'Новый'
                    && request.resource.data.createdAt == request.time;

      // Update access is split for admins and employees.
      allow update: if isAdmin()
                    || (
                      isEmployee() && resource.data.createdBy == request.auth.token.email &&
                      // Employees cannot change sensitive fields.
                      request.resource.data.createdBy == resource.data.createdBy &&
                      request.resource.data.profit == resource.data.profit &&
                      request.resource.data.payment_sum == resource.data.payment_sum &&
                      request.resource.data.delivery_cost == resource.data.delivery_cost
                    );
    }
    
    // JAMBS
    match /jambs/{jambId} {
      allow read, write: if isAdmin();
    }
    
    // Consolidations
    match /consolidations/{consolidationId} {
      allow read, create, update, delete: if isAdmin();
    }
  }
}
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    // Проверка роли через Custom Claims (вместо чтения из Firestore)
    function hasClaim(role) {
      return isAuth() && request.auth.token[role] == true;
    }

    function isAdmin() {
      return hasClaim('admin');
    }

    function isEmployee() {
      return hasClaim('employee') || isAdmin();
    }

    // Users - чтение только своих данных или админом
    match /users/{email} {
      allow read: if request.auth.token.email == email || isAdmin();
      allow create: if isAdmin();
      allow update: if (request.auth.token.email == email || isAdmin())
                    && request.resource.data.role == resource.data.role;
    }

    // Orders
    match /orders/{orderId} {
      // Read access for employees and admins.
      allow read: if isEmployee();

      // Delete access only for admins.
      allow delete: if isAdmin();

      // Create access for any authenticated user, with validation.
      allow create: if isAuth()
                    && request.resource.data.createdBy == request.auth.token.email
                    && request.resource.data.status == 'Новый'
                    && request.resource.data.createdAt == request.time;

      // Update access is split for admins and employees.
      allow update: if isAdmin()
                    || (
                      isEmployee() && resource.data.createdBy == request.auth.token.email &&
                      // Employees cannot change sensitive fields.
                      request.resource.data.createdBy == resource.data.createdBy &&
                      request.resource.data.profit == resource.data.profit &&
                      request.resource.data.payment_sum == resource.data.payment_sum &&
                      request.resource.data.delivery_cost == resource.data.delivery_cost
                    );
    }

    // JAMBS - только админы
    match /jambs/{jambId} {
      allow read, write: if isAdmin();
    }

    // Consolidations - только админы
    match /consolidations/{consolidationId} {
      allow read, create, update, delete: if isAdmin();
    }
    
    // Shipments - только админы
    match /shipments/{shipmentId} {
      allow read, create, update, delete: if isAdmin();
    }
    
    // Returns - только админы
    match /returns/{returnId} {
      allow read, create, update, delete: if isAdmin();
    }
  }
}
